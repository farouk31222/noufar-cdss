# Copy this file to .env and fill in your values
# NEVER commit the .env file to GitHub

PORT=5000
FLASK_AI_URL=http://ai-server:5001
MONGODB_URI=mongodb://mongo:27017/noufar_cdss
NODE_ENV=production

# Change these to strong secret values!
JWT_SECRET=change_me_to_a_strong_secret
ADMIN_REGISTRATION_KEY=change_me_to_a_strong_key

# Your Gmail credentials for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="NOUFAR CDSS <your_email@gmail.com>"
